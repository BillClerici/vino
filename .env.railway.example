# Railway Environment Variables
# Copy these into Railway Dashboard → Project → Variables
# Railway auto-provides: PORT, RAILWAY_PUBLIC_DOMAIN

# Django Core
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=generate-a-strong-secret-key
DEBUG=False
ALLOWED_HOSTS=your-app.up.railway.app

# Database — use Railway Postgres plugin (auto-injected) or Supabase
DATABASE_URL=postgres://user:pass@host:port/dbname
DATABASE_URL_DIRECT=postgres://user:pass@host:5432/dbname

# Redis — use Railway Redis plugin (auto-injected)
REDIS_URL=redis://default:pass@host:port

# OAuth — Google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth — Microsoft
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common

# Stripe — User Subscriptions
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_MONTHLY_PRICE_ID=price_xxx
STRIPE_YEARLY_PRICE_ID=price_xxx

# Stripe — Partner Subscriptions
STRIPE_PARTNER_SILVER_MONTHLY_PRICE_ID=price_xxx
STRIPE_PARTNER_SILVER_YEARLY_PRICE_ID=price_xxx
STRIPE_PARTNER_GOLD_MONTHLY_PRICE_ID=price_xxx
STRIPE_PARTNER_GOLD_YEARLY_PRICE_ID=price_xxx
STRIPE_PARTNER_PLATINUM_MONTHLY_PRICE_ID=price_xxx
STRIPE_PARTNER_PLATINUM_YEARLY_PRICE_ID=price_xxx

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-key

# LLM / AI Keys
ANTHROPIC_API_KEY=sk-ant-xxx
GOOGLE_API_KEY=your-gemini-key
OPENAI_API_KEY=sk-proj-xxx
GROQ_API_KEY=gsk_xxx
PERPLEXITY_API_KEY=pplx-xxx
TAVILY_API_KEY=tvly-xxx

# Pinecone (Vector DB)
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=vinovoyage

# Token Encryption
FIELD_ENCRYPTION_KEY=generate-with-python-fernet

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=trip-me-7c9dc
GOOGLE_REFRESH_TOKEN=your-refresh-token

# CORS / CSRF
CORS_ALLOWED_ORIGINS=https://your-app.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app

# Sentry (optional)
SENTRY_DSN=

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Trip Me <noreply@tripme.app>
